{
  "version": "0.2.2",
  "tasks": {
    "fmt": "deno task fmt:dprint",
    "fmt:check": "deno task fmt:dprint:check",
    "fmt:dprint": "deno run -A npm:dprint@0.49.0 fmt --config dprint.json",
    "fmt:dprint:check": "deno run -A npm:dprint@0.49.0 check --config dprint.json",
    "lint": "cd packages/tufa && deno task lint && cd ../keri && deno task lint && cd ../cesr && deno task lint && cd ../.. && deno lint scripts --rules-tags=recommended --rules-exclude=no-import-prefix,no-unversioned-import,verbatim-module-syntax,no-explicit-any,no-unused-vars,prefer-const,require-yield",
    "docs:check": "deno run --allow-read scripts/check_class_docstrings.ts",
    "inline-code:check": "deno run --allow-read scripts/check_no_inline_code.ts",
    "check": "cd packages/tufa && deno task check && cd ../keri && deno task check && cd ../cesr && deno check mod.ts && cd ../.. && deno run --allow-read scripts/check_no_direct_cbor_x.ts",
    "quality:check": "deno task docs:check && deno task inline-code:check && deno task check && deno task version:check",
    "quality": "deno task fmt:check && deno task lint && deno task quality:check && deno task test:quality && deno task test:cesr",
    "quality:report": "deno run --allow-run=rg,scc --allow-read --allow-env=PATH,HOME,TMPDIR scripts/quality-report.ts",
    "manifest:sync": "deno run -A scripts/sync_manifest_versions.ts",
    "manifest:check": "deno run -A scripts/sync_manifest_versions.ts --check",
    "version:generate": "deno run -A scripts/generate_versions.ts",
    "version:generate:ci": "deno run -A scripts/generate_versions.ts --ci-build-metadata",
    "version:check": "deno task manifest:check && deno run -A scripts/generate_versions.ts --check",
    "build:npm": "deno task version:generate && cd packages/keri && deno task build:npm",
    "tufa:build:npm": "cd packages/tufa && deno task build:npm",
    "smoke:keri:npm": "bash scripts/smoke-test-keri-npm.sh",
    "smoke:tephra:npm": "bash scripts/smoke-test-tephra-npm.sh",
    "smoke:tufa:npm": "bash scripts/smoke-test-tufa-npm.sh",
    "changeset:check": "bash scripts/ci/check-changeset.sh",
    "release:changeset": "npx --yes @changesets/cli add",
    "release:changeset:empty": "npx --yes @changesets/cli add --empty",
    "release:version": "npx --yes @changesets/cli version && deno task manifest:sync && deno task version:generate",
    "release:publish": "npx --yes @changesets/cli publish",
    "release:verify:tufa": "deno task fmt:check && deno task version:check && deno task test:quality:tufa && deno task npm:build:all && deno task smoke:tufa:npm",
    "hooks:install": "lefthook install",
    "hooks:pre-push": "lefthook run pre-push --force",
    "setup": "cd packages/keri && deno task setup:compat-lmdb",
    "setup:compat-lmdb": "cd packages/keri && deno task setup:compat-lmdb",
    "start": "cd packages/tufa && deno task start",
    "dev": "cd packages/tufa && deno task dev",
    "tufa": "cd packages/tufa && deno task tufa",
    "test": "cd packages/tufa && deno task test && cd ../keri && deno task test && cd ../cesr && deno task test",
    "test:quality": "cd packages/tufa && deno task test:quality && cd ../keri && deno task test:quality",
    "test:slow": "cd packages/keri && deno task test:slow",
    "test:quality:tufa": "cd packages/tufa && deno task test:quality",
    "test:quality:keri:fast": "cd packages/keri && deno task test:quality:db-fast && deno task test:quality:core-fast && deno task test:quality:app-fast && deno task test:quality:runtime-medium",
    "test:quality:keri:db-fast": "cd packages/keri && deno task test:quality:db-fast",
    "test:quality:keri:core-fast-a": "cd packages/keri && deno task test:quality:core-fast-a",
    "test:quality:keri:core-fast-b": "cd packages/keri && deno task test:quality:core-fast-b",
    "test:quality:keri:core-fast": "cd packages/keri && deno task test:quality:core-fast",
    "test:quality:keri:core-fast-parallel": "cd packages/keri && deno task test:quality:core-fast-parallel",
    "test:quality:keri:app-fast": "cd packages/keri && deno task test:quality:app-fast",
    "test:quality:keri:app-fast-parallel": "cd packages/keri && deno task test:quality:app-fast-parallel",
    "test:quality:keri:app-fast-isolated": "cd packages/keri && deno task test:quality:app-fast-isolated",
    "test:quality:keri:runtime-medium": "cd packages/keri && deno task test:quality:runtime-medium",
    "test:quality:keri:runtime-slow": "cd packages/keri && deno task test:quality:runtime-slow",
    "test:quality:keri:app-stateful-a": "cd packages/keri && deno task test:quality:app-stateful-a",
    "test:quality:keri:app-stateful-b": "cd packages/keri && deno task test:quality:app-stateful-b",
    "test:quality:keri:interop-parity": "cd packages/keri && deno task test:quality:interop-parity",
    "test:quality:keri:interop-acdc-extended": "cd packages/keri && deno task test:quality:interop-acdc-extended",
    "test:quality:keri:interop-acdc-deep": "cd packages/keri && deno task test:quality:interop-acdc-deep",
    "test:quality:keri:extended-interop": "cd packages/keri && deno task test:quality:extended-interop",
    "test:quality:keri:full": "cd packages/keri && deno task test:quality:full",
    "test:quality:keri:interop-delegation": "cd packages/keri && deno task test:quality:interop-delegation",
    "test:quality:keri:interop-mailbox-slow": "cd packages/keri && deno task test:quality:interop-mailbox-slow",
    "test:quality:keri:interop-witness": "cd packages/keri && deno task test:quality:interop-witness",
    "test:quality:keri:interop-did-webs": "cd packages/keri && deno task test:quality:interop-did-webs",
    "test:quality:keri:interop-gates-b": "cd packages/keri && deno task test:quality:interop-gates-b",
    "test:quality:keri:interop-gates-c": "cd packages/keri && deno task test:quality:interop-gates-c",
    "test:integration:server": "cd packages/tufa && deno task test:integration:server",
    "test:cesr": "cd packages/cesr && deno task test",
    "bench:cesr": "cd packages/cesr && deno task bench",
    "tephra:bench": "cd packages/cesr && deno task bench:parser",
    "tephra:annotate": "cd packages/cesr && deno task annotate",
    "tephra:validate": "cd packages/cesr && deno task validate",
    "tephra:build:npm": "deno task version:generate && cd packages/cesr && deno task build:npm",
    "npm:build:all": "deno task build:npm && deno task tephra:build:npm && deno task tufa:build:npm",
    "docker:did-webs-ts:build": "bash scripts/docker/did-webs-ts.sh build",
    "docker:did-webs-ts:test": "bash scripts/docker/did-webs-ts.sh test",
    "docker:did-webs-ts:push": "bash scripts/docker/did-webs-ts.sh push",
    "docker:did-webs-ts:build-push": "bash scripts/docker/did-webs-ts.sh build-push"
  },
  "fmt": {
    "include": [
      "**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,md}"
    ],
    "exclude": [
      "**/.deno-cache/**",
      "**/node_modules/**",
      "**/npm/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/*-lock.json",
      "**/*-lock.yaml"
    ],
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "semiColons": true
  },
  "imports": {
    "@msgpack/msgpack": "npm:@msgpack/msgpack@^3.1.2",
    "cbor-x": "npm:cbor-x@^1.6.0",
    "cbor-x/decode": "npm:cbor-x@^1.6.0/decode",
    "cbor-x/encode": "npm:cbor-x@^1.6.0/encode",
    "cesr-ts": "./packages/cesr/mod.ts",
    "keri-ts": "./packages/keri/mod.ts",
    "keri-ts/cli": "./packages/keri/cli.ts",
    "keri-ts/runtime": "./packages/keri/runtime.ts",
    "keri-ts/db": "./packages/keri/db.ts",
    "effection": "npm:effection@^3.6.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns",
      "dom"
    ]
  },
  "allowScripts": [
    "npm:cbor-extract@2.2.0",
    "npm:dprint@0.49.0",
    "npm:lmdb@3.5.3",
    "npm:msgpackr-extract@2.2.0",
    "npm:msgpackr-extract@3.0.3"
  ]
}
