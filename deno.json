{
  "version": "0.2.2",
  "tasks": {
    "fmt": "deno run -A npm:dprint@0.49.0 fmt",
    "fmt:check": "deno run -A npm:dprint@0.49.0 check",
    "lint": "cd packages/keri && deno task lint && cd ../cesr && deno task lint && cd ../.. && deno lint scripts --rules-tags=recommended --rules-exclude=no-import-prefix,no-unversioned-import,verbatim-module-syntax,no-explicit-any,no-unused-vars,prefer-const,require-yield",
    "docs:check": "deno run --allow-read scripts/check_class_docstrings.ts",
    "check": "cd packages/keri && deno task check && cd ../cesr && deno check mod.ts && cd ../.. && deno run --allow-read scripts/check_no_direct_cbor_x.ts",
    "quality:check": "deno task docs:check && deno task check && deno task version:check",
    "quality": "deno task fmt:check && deno task lint && deno task quality:check && deno task test:quality && deno task test:cesr",
    "quality:report": "deno run --allow-run=rg,scc --allow-read --allow-env=PATH,HOME,TMPDIR scripts/quality-report.ts",
    "manifest:sync": "deno run -A scripts/sync_manifest_versions.ts",
    "manifest:check": "deno run -A scripts/sync_manifest_versions.ts --check",
    "version:generate": "deno run -A scripts/generate_versions.ts",
    "version:generate:ci": "deno run -A scripts/generate_versions.ts --ci-build-metadata",
    "version:check": "deno task manifest:check && deno run -A scripts/generate_versions.ts --check",
    "build:npm": "deno task version:generate && cd packages/keri && deno task build:npm",
    "smoke:keri:npm": "bash scripts/smoke-test-keri-npm.sh",
    "release:changeset": "npx --yes @changesets/cli add",
    "release:version": "npx --yes @changesets/cli version && deno task manifest:sync && deno task version:generate",
    "release:publish": "npx --yes @changesets/cli publish",
    "setup": "cd packages/keri && deno task setup:compat-lmdb",
    "setup:compat-lmdb": "cd packages/keri && deno task setup:compat-lmdb",
    "start": "cd packages/keri && deno task start",
    "dev": "cd packages/keri && deno task dev",
    "tufa": "cd packages/keri && deno task tufa",
    "test": "cd packages/keri && deno task test && cd ../cesr && deno task test",
    "test:quality": "cd packages/keri && deno task test:quality",
    "test:slow": "cd packages/keri && deno task test:slow",
    "test:quality:keri:fast": "cd packages/keri && deno task test:quality:db-fast && deno task test:quality:core-fast && deno task test:quality:app-fast && deno task test:quality:server && deno task test:quality:runtime-medium",
    "test:quality:keri:db-fast": "cd packages/keri && deno task test:quality:db-fast",
    "test:quality:keri:core-fast-a": "cd packages/keri && deno task test:quality:core-fast-a",
    "test:quality:keri:core-fast-b": "cd packages/keri && deno task test:quality:core-fast-b",
    "test:quality:keri:core-fast": "cd packages/keri && deno task test:quality:core-fast",
    "test:quality:keri:core-fast-parallel": "cd packages/keri && deno task test:quality:core-fast-parallel",
    "test:quality:keri:app-fast": "cd packages/keri && deno task test:quality:app-fast && deno task test:quality:server",
    "test:quality:keri:app-fast-parallel": "cd packages/keri && deno task test:quality:app-fast-parallel",
    "test:quality:keri:app-fast-isolated": "cd packages/keri && deno task test:quality:app-fast-isolated",
    "test:quality:keri:runtime-medium": "cd packages/keri && deno task test:quality:runtime-medium",
    "test:quality:keri:runtime-slow": "cd packages/keri && deno task test:quality:runtime-slow",
    "test:quality:keri:app-stateful-a": "cd packages/keri && deno task test:quality:app-stateful-a",
    "test:quality:keri:app-stateful-b": "cd packages/keri && deno task test:quality:app-stateful-b",
    "test:quality:keri:interop-parity": "cd packages/keri && deno task test:quality:interop-parity",
    "test:quality:keri:interop-witness": "cd packages/keri && deno task test:quality:interop-witness",
    "test:quality:keri:interop-gates-b": "cd packages/keri && deno task test:quality:interop-gates-b",
    "test:quality:keri:interop-gates-c": "cd packages/keri && deno task test:quality:interop-gates-c",
    "test:integration:server": "cd packages/keri && deno task test:integration:server",
    "test:cesr": "cd packages/cesr && deno task test",
    "bench:cesr": "cd packages/cesr && deno task bench",
    "bench:cesr:parser": "cd packages/cesr && deno task bench:parser",
    "cesr:annotate": "cd packages/cesr && deno task annotate",
    "cesr:build:npm": "deno task version:generate && cd packages/cesr && deno task build:npm",
    "npm:build:all": "deno task build:npm && deno task cesr:build:npm"
  },
  "imports": {
    "@msgpack/msgpack": "npm:@msgpack/msgpack@^3.1.2",
    "cbor-x": "npm:cbor-x@^1.6.0",
    "cbor-x/decode": "npm:cbor-x@^1.6.0/decode",
    "cbor-x/encode": "npm:cbor-x@^1.6.0/encode",
    "cesr-ts": "./packages/cesr/mod.ts"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns",
      "dom"
    ]
  },
  "allowScripts": [
    "npm:cbor-extract@2.2.0",
    "npm:dprint@0.49.0",
    "npm:lmdb@3.5.3",
    "npm:msgpackr-extract@2.2.0",
    "npm:msgpackr-extract@3.0.3"
  ]
}
