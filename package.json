{
  "name": "keri-ts-workspace",
  "version": "0.2.2",
  "private": true,
  "description": "Monorepo workspace and release tooling for keri-ts and cesr-ts",
  "license": "Apache-2.0",
  "dependencies": {
    "lmdb": "git+https://github.com/kentbull/lmdb-js.git#d1c29f07d394afcec746ebef20d6e1c706388092"
  },
  "workspaces": [
    "packages/tufa",
    "packages/keri",
    "packages/cesr"
  ],
  "scripts": {
    "changeset": "npx --yes @changesets/cli add",
    "version-packages": "npx --yes @changesets/cli version",
    "publish-packages": "npx --yes @changesets/cli publish",
    "smoke:keri:npm": "bash scripts/smoke-test-keri-npm.sh",
    "smoke:tufa:npm": "bash scripts/smoke-test-tufa-npm.sh"
  }
}
