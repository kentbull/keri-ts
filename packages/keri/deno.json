{
  "name": "keri-ts",
  "version": "0.5.0",
  "exports": {
    ".": "./mod.ts"
  },
  "tasks": {
    "fmt": "deno run -A npm:dprint@0.49.0 fmt --config ../../dprint.json .",
    "fmt:check": "deno run -A npm:dprint@0.49.0 check --config ../../dprint.json .",
    "lint": "deno lint mod.ts src test scripts --rules-tags=recommended --rules-exclude=no-import-prefix,no-unversioned-import,verbatim-module-syntax,no-explicit-any,no-unused-vars,prefer-const,require-yield",
    "check": "deno check mod.ts ../cesr/mod.ts",
    "quality": "deno task fmt:check && deno task lint && deno task check && deno task version:check && deno task test:quality",
    "manifest:sync": "deno run -A ../../scripts/sync_manifest_versions.ts",
    "manifest:check": "deno run -A ../../scripts/sync_manifest_versions.ts --check",
    "version:generate": "deno run -A ../../scripts/generate_versions.ts --only keri",
    "version:check": "deno task manifest:check && deno run -A ../../scripts/generate_versions.ts --check --only keri",
    "build:npm": "deno task version:generate && deno run -A scripts/build_npm.ts",
    "setup": "deno task setup:compat-lmdb",
    "setup:compat-lmdb": "bash scripts/setup_lmdb_v1.sh",
    "start": "deno run --allow-all --unstable-ffi mod.ts",
    "dev": "deno run --allow-all --unstable-ffi --watch mod.ts",
    "tufa": "deno run --allow-all --unstable-ffi mod.ts",
    "test": "bash ../../scripts/ci/run-keri-test-group.sh full",
    "test:quality": "bash ../../scripts/ci/run-keri-test-group.sh quality",
    "test:slow": "bash ../../scripts/ci/run-keri-test-group.sh slow",
    "test:lane-audit": "bash ../../scripts/ci/run-keri-test-group.sh lane-audit",
    "test:quality:db-fast": "bash ../../scripts/ci/run-keri-test-group.sh db-fast",
    "test:quality:core-fast": "bash ../../scripts/ci/run-keri-test-group.sh core-fast",
    "test:quality:app-fast": "bash ../../scripts/ci/run-keri-test-group.sh app-fast",
    "test:quality:app-fast-parallel": "bash ../../scripts/ci/run-keri-test-group.sh app-fast-parallel",
    "test:quality:app-fast-isolated": "bash ../../scripts/ci/run-keri-test-group.sh app-fast-isolated",
    "test:quality:app-light": "bash ../../scripts/ci/run-keri-test-group.sh app-fast",
    "test:quality:server": "bash ../../scripts/ci/run-keri-test-group.sh server",
    "test:quality:runtime-medium": "bash ../../scripts/ci/run-keri-test-group.sh runtime-medium",
    "test:quality:runtime-slow": "bash ../../scripts/ci/run-keri-test-group.sh runtime-slow",
    "test:quality:app-stateful-a": "bash ../../scripts/ci/run-keri-test-group.sh app-stateful-a",
    "test:quality:app-stateful-b": "bash ../../scripts/ci/run-keri-test-group.sh app-stateful-b",
    "test:quality:interop-parity": "bash ../../scripts/ci/run-keri-test-group.sh interop-parity",
    "test:quality:interop-witness": "bash ../../scripts/ci/run-keri-test-group.sh interop-witness",
    "test:quality:interop-gates-b": "bash ../../scripts/ci/run-keri-test-group.sh interop-gates-b",
    "test:quality:interop-gates-c": "bash ../../scripts/ci/run-keri-test-group.sh interop-gates-c",
    "test:slow:runtime": "bash ../../scripts/ci/run-keri-test-group.sh runtime-slow",
    "test:slow:interop-mailbox": "bash ../../scripts/ci/run-keri-test-group.sh interop-mailbox-slow",
    "test:integration:server": "bash ../../scripts/ci/run-keri-test-group.sh server"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@msgpack/msgpack": "npm:@msgpack/msgpack@^3.1.2",
    "cbor-x": "npm:cbor-x@^1.6.0",
    "cbor-x/decode": "npm:cbor-x@^1.6.0/decode",
    "cbor-x/encode": "npm:cbor-x@^1.6.0/encode",
    "effection": "npm:effection@^3.6.0",
    "commander": "npm:commander@^10.0.1",
    "jsr:@std/assert": "jsr:@std/assert@^0.217.0",
    "cesr-ts": "../cesr/mod.ts"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns",
      "dom"
    ]
  }
}
