{
  "name": "tufa",
  "version": "0.5.0",
  "exports": {
    ".": "./mod.ts"
  },
  "tasks": {
    "version:generate": "deno run -A ../../scripts/generate_versions.ts --only tufa",
    "fmt": "deno run -A npm:dprint@0.49.0 fmt --config ../../dprint.json .",
    "fmt:check": "deno run -A npm:dprint@0.49.0 check --config ../../dprint.json .",
    "lint": "deno lint mod.ts src scripts --rules-tags=recommended --rules-exclude=no-import-prefix,no-unversioned-import,verbatim-module-syntax,no-explicit-any,no-unused-vars,prefer-const,require-yield",
    "check": "deno check mod.ts src/npm/index.ts src/app/cli-node.ts scripts/build_npm.ts test/*.ts test/integration/*.ts",
    "build:npm": "deno task version:generate && deno run -A scripts/build_npm.ts",
    "start": "deno run --allow-all --unstable-ffi mod.ts",
    "dev": "deno run --allow-all --unstable-ffi --watch mod.ts",
    "tufa": "deno run --allow-all --unstable-ffi mod.ts",
    "test": "deno test -A test",
    "test:quality": "deno test -A test",
    "test:integration:server": "deno test -A test/integration/server.test.ts"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "cesr-ts": "../cesr/mod.ts",
    "keri-ts": "../keri/mod.ts",
    "keri-ts/runtime": "../keri/runtime.ts",
    "keri-ts/db": "../keri/db.ts",
    "effection": "npm:effection@^3.6.0"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns",
      "dom"
    ]
  }
}
